<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <rotate
            android:fromDegrees="45"
            android:toDegrees="45"
            android:pivotX="0%"
            android:pivotY="80%">
            <shape android:shape="rectangle">
                <solid android:color="@color/theme_2" />
            </shape>
        </rotate>
    </item>
</layer-list>

